# =============================================================================
# Static System Analyzer - Environment Configuration
# =============================================================================
# Copy this file to config/.env and fill in your values.
#
# cp config/.env.example config/.env
# =============================================================================

# ---- Bitbucket / Git Credentials (for Clone stage) ----
# BASE_URL=https://bitbucket.example.com/scm
# USERNAME=your_username
# TOKEN=your_personal_access_token

# ---- Code Metrics Configuration ----
# ck (https://github.com/mauricioaniche/ck) runs locally inside the Docker container.
# No external server configuration is needed.
# The ck JAR path is set via CK_JAR_PATH environment variable in the Dockerfile.
