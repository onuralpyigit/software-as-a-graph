{
  "metadata": {
    "domain": "robotics",
    "framework": "ROS 2",
    "scenario": "autonomous_vehicle"
  },
  "nodes": [
    { "id": "N0", "name": "ECU_Sensor_Front" },
    { "id": "N1", "name": "ECU_Fusion" },
    { "id": "N2", "name": "ECU_Planning" },
    { "id": "N3", "name": "ECU_Actuator" },
    { "id": "N4", "name": "ECU_Broker_Host" } // Shared compute for DDS discovery
  ],
  "brokers": [
    { "id": "B0", "name": "FastDDS_Discovery_Server" }
  ],
  "topics": [
    { 
      "id": "T0", "name": "/scan", "size": 524288, 
      "qos": { "durability": "VOLATILE", "reliability": "BEST_EFFORT", "transport_priority": "MEDIUM" } 
      // Sensors use BEST_EFFORT to prioritize latency over 100% delivery.
    },
    { 
      "id": "T1", "name": "/image_raw", "size": 2097152, 
      "qos": { "durability": "VOLATILE", "reliability": "BEST_EFFORT", "transport_priority": "LOW" } 
    },
    { 
      "id": "T2", "name": "/processed_objects", "size": 1024, 
      "qos": { "durability": "TRANSIENT_LOCAL", "reliability": "RELIABLE", "transport_priority": "HIGH" } 
      // Fusion output is critical and small, using RELIABLE + TRANSIENT_LOCAL for late-joiners.
    },
    { 
      "id": "T3", "name": "/global_path", "size": 65536, 
      "qos": { "durability": "TRANSIENT_LOCAL", "reliability": "RELIABLE", "transport_priority": "MEDIUM" } 
    },
    { 
      "id": "T4", "name": "/twist_cmd", "size": 128, 
      "qos": { "durability": "VOLATILE", "reliability": "RELIABLE", "transport_priority": "URGENT" } 
      // Control commands are URGENT and must be RELIABLE.
    }
  ],
  "applications": [
    { 
      "id": "A0", "name": "Lidar_Driver", "role": "pub", "app_type": "sensor", "criticality": true,
      "code_metrics": { "size": { "total_loc": 2500 }, "complexity": { "avg_wmc": 8.0 }, "coupling": { "avg_fanout": 2 } }
    },
    { 
      "id": "A1", "name": "Camera_Driver", "role": "pub", "app_type": "sensor", "criticality": false,
      "code_metrics": { "size": { "total_loc": 5000 }, "complexity": { "avg_wmc": 12.0 }, "coupling": { "avg_fanout": 1 } }
    },
    { 
      "id": "A2", "name": "Sensor_Fusion_Node", "role": "pubsub", "app_type": "processor", "criticality": true,
      "code_metrics": { "size": { "total_loc": 15000 }, "complexity": { "avg_wmc": 25.0 }, "coupling": { "avg_fanin": 2, "avg_fanout": 1 } }
    },
    { 
      "id": "A3", "name": "Path_Planner", "role": "pubsub", "app_type": "controller", "criticality": true,
      "code_metrics": { "size": { "total_loc": 25000 }, "complexity": { "avg_wmc": 35.0 }, "coupling": { "avg_fanin": 1, "avg_fanout": 1 } }
    },
    { 
      "id": "A4", "name": "Motion_Controller", "role": "pubsub", "app_type": "controller", "criticality": true,
      "code_metrics": { "size": { "total_loc": 8000 }, "complexity": { "avg_wmc": 18.0 }, "coupling": { "avg_fanin": 1, "avg_fanout": 1 } }
    },
    { 
      "id": "A5", "name": "Drive_By_Wire", "role": "sub", "app_type": "actuator", "criticality": true,
      "code_metrics": { "size": { "total_loc": 1200 }, "complexity": { "avg_wmc": 6.0 }, "coupling": { "avg_fanin": 1 } }
    }
  ],
  "libraries": [
    { "id": "L0", "name": "Eigen_Math_Lib", "version": "3.4.0" },
    { "id": "L1", "name": "OpenCV_Core", "version": "4.5.3" }
  ],
  "relationships": {
    "runs_on": [
      { "from": "A0", "to": "N0" }, { "from": "A1", "to": "N0" },
      { "from": "A2", "to": "N1" }, { "from": "A3", "to": "N2" },
      { "from": "A4", "to": "N3" }, { "from": "A5", "to": "N3" },
      { "from": "B0", "to": "N4" }
    ],
    "routes": [
      { "from": "B0", "to": "T0" }, { "from": "B0", "to": "T1" },
      { "from": "B0", "to": "T2" }, { "from": "B0", "to": "T3" },
      { "from": "B0", "to": "T4" }
    ],
    "publishes_to": [
      { "from": "A0", "to": "T0" }, { "from": "A1", "to": "T1" },
      { "from": "A2", "to": "T2" }, { "from": "A3", "to": "T3" },
      { "from": "A4", "to": "T4" }
    ],
    "subscribes_to": [
      { "from": "A2", "to": "T0" }, { "from": "A2", "to": "T1" },
      { "from": "A3", "to": "T2" }, { "from": "A4", "to": "T3" },
      { "from": "A5", "to": "T4" }
    ],
    "uses": [
      { "from": "A2", "to": "L0" }, { "from": "A2", "to": "L1" },
      { "from": "A3", "to": "L0" }
    ]
  }
}
