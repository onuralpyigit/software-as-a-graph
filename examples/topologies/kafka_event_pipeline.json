{
  "metadata": {
    "domain": "data_engineering",
    "framework": "Kafka",
    "scenario": "event_pipeline"
  },
  "nodes": [
    { "id": "N0", "name": "Kafka_Broker_Node_1" },
    { "id": "N1", "name": "Kafka_Broker_Node_2" },
    { "id": "N2", "name": "Producer_Node" },
    { "id": "N3", "name": "Consumer_Node_A" },
    { "id": "N4", "name": "Registry_Host" }
  ],
  "brokers": [
    { "id": "B0", "name": "Kafka_Cluster" }
  ],
  "topics": [
    { 
      "id": "T0", "name": "orders", "size": 10485760, 
      "qos": { "durability": "PERSISTENT", "reliability": "RELIABLE", "transport_priority": "HIGH" } 
      // Orders must be PERSISTENT and RELIABLE to ensure zero data loss for financial transactions.
    },
    { 
      "id": "T1", "name": "inventory_updates", "size": 1048576, 
      "qos": { "durability": "TRANSIENT_LOCAL", "reliability": "RELIABLE", "transport_priority": "MEDIUM" } 
      // Inventory updates use TRANSIENT_LOCAL so new consumers get the latest state immediately.
    },
    { 
      "id": "T2", "name": "analytics_events", "size": 104857600, 
      "qos": { "durability": "VOLATILE", "reliability": "BEST_EFFORT", "transport_priority": "LOW" } 
      // High-volume analytics can tolerate loss; BEST_EFFORT prevents backpressure on producers.
    }
  ],
  "applications": [
    { 
      "id": "A0", "name": "Order_Service", "role": "pub", "app_type": "gateway", "criticality": true,
      "code_metrics": { "size": { "total_loc": 12000 }, "complexity": { "avg_wmc": 15.0 }, "coupling": { "avg_fanout": 2 } }
    },
    { 
      "id": "A1", "name": "Inventory_Service", "role": "pubsub", "app_type": "processor", "criticality": true,
      "code_metrics": { "size": { "total_loc": 8500 }, "complexity": { "avg_wmc": 10.0 }, "coupling": { "avg_fanin": 2, "avg_fanout": 1 } }
    },
    { 
      "id": "A2", "name": "Shipping_Service", "role": "sub", "app_type": "actuator", "criticality": true,
      "code_metrics": { "size": { "total_loc": 4500 }, "complexity": { "avg_wmc": 8.0 }, "coupling": { "avg_fanin": 1 } }
    },
    { 
      "id": "A3", "name": "Analytics_Worker", "role": "sub", "app_type": "monitor", "criticality": false,
      "code_metrics": { "size": { "total_loc": 32000 }, "complexity": { "avg_wmc": 22.0 }, "coupling": { "avg_fanin": 1 } }
    }
  ],
  "libraries": [
    { 
      "id": "L0", "name": "Schema_Registry_Client", "version": "6.2.0",
      "code_metrics": { "size": { "total_loc": 25000 }, "complexity": { "avg_wmc": 30.0 }, "coupling": { "avg_fanin": 4 } }
      // Library node: Failure here simulates a broken schema registry client, affecting all services simultaneously.
    }
  ],
  "relationships": {
    "runs_on": [
      { "from": "A0", "to": "N2" }, { "from": "A1", "to": "N3" },
      { "from": "A2", "to": "N3" }, { "from": "A3", "to": "N3" },
      { "from": "B0", "to": "N0" }, { "from": "B0", "to": "N1" }
    ],
    "routes": [
      { "from": "B0", "to": "T0" }, { "from": "B0", "to": "T1" }, { "from": "B0", "to": "T2" }
    ],
    "publishes_to": [
      { "from": "A0", "to": "T0" }, { "from": "A1", "to": "T1" }
    ],
    "subscribes_to": [
      { "from": "A1", "to": "T0" }, { "from": "A2", "to": "T1" }, { "from": "A3", "to": "T2" }
    ],
    "uses": [
      { "from": "A0", "to": "L0" }, { "from": "A1", "to": "L0" },
      { "from": "A2", "to": "L0" }, { "from": "A3", "to": "L0" }
    ]
  }
}
